{
  "name": "thc-games-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "verify:connections": "node scripts/verify-connections.mjs",
    "dev": "npm run dev:high-land",
    "build": "npm run build:high-land",
    "test": "npm run test:high-land",
    "test:e2e": "npm run test:e2e:high-land",
    "dev:high-land": "npm --workspace apps/high-land-web run dev",
    "build:high-land": "npm --workspace apps/high-land-web run build",
    "test:high-land": "npm --workspace apps/high-land-web run test",
    "test:e2e:high-land": "npm --workspace apps/high-land-web run test:e2e",
    "dev:growlens": "npm --workspace apps/high-land-web exec -- vite --config ../growlens-web/vite.config.ts",
    "build:growlens": "npm --workspace apps/high-land-web exec -- tsc -p ../growlens-web/tsconfig.json && npm --workspace apps/high-land-web exec -- vite build --config ../growlens-web/vite.config.ts",
    "test:growlens": "npm --workspace apps/high-land-web exec -- vitest run --config ../growlens-web/vitest.config.ts",
    "verify:growlens": "npm run test:growlens && npm run build:growlens"
  }
}
