# High Land browser app public config
# Copy this file to .env.local for local development.
# Never commit real .env or .env.local files.

# Supabase browser-safe values only.
# Get these from Supabase Dashboard > Project Settings / Connect > API Keys.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional static game server URL for local/non-Supabase multiplayer experiments.
# Leave blank for local-only pass-and-play mode.
VITE_GAME_SERVER_URL=
