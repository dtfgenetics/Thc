# Frontend-safe environment example
# Copy this file to .env.local for local development.
# Never commit real secrets.

# Public frontend values
VITE_APP_NAME=High Land
VITE_APP_BASE_URL=http://localhost:5173

# The multiplayer API is same-origin and requires no browser credential.

# Optional analytics placeholder
VITE_ANALYTICS_ID=

# Server-only secrets must NOT be placed in browser code.
