# Frontend-safe environment example
# Copy this file to .env.local for local development.
# Never commit real secrets.

# Public frontend values
VITE_APP_NAME=High Land
VITE_APP_BASE_URL=http://localhost:5173

# Supabase public frontend values
# These are placeholders only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional analytics placeholder
VITE_ANALYTICS_ID=

# Server-only secrets must NOT be placed in browser code.
# SUPABASE_SERVICE_ROLE_KEY belongs only in server-side environment settings.
